{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public and private information for app users.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "isBlocked": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email"]
    },
    "ServiceRequest": {
      "title": "Service Request",
      "description": "Requests for marketing services submitted by users.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "service": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "details": { "type": "string" },
        "duration": { "type": "string" },
        "mediaLinks": { "type": "string" },
        "files": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["pending", "in-progress", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["service", "name", "phone", "status"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Stores user profiles."
    },
    "serviceRequests/{requestId}": {
      "schema": "ServiceRequest",
      "description": "Stores marketing service requests."
    }
  }
}
